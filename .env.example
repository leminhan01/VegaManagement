# ============================================================
# VegiFlow — Environment Variables Reference
# ============================================================
# Copy this file to .env in each service directory and fill in values

# ── Backend (NestJS) ──────────────────────────────────────
# backend/.env
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/veg_shop

# JWT
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=24h

# Customer JWT (storefront auth) — secret riêng, cô lập với admin JWT
CUSTOMER_JWT_SECRET=your-customer-jwt-secret-change-me

# Bot API Key (phải trùng với chatbot/.env)
BOT_API_KEY=your-secure-api-key-here

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ── Admin (Next.js) ───────────────────────────────────────
# admin/.env
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_APP_NAME=VegiFlow Admin

# ── Chatbot (Python) ──────────────────────────────────────
# chatbot/.env
PORT=8000
HOST=0.0.0.0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_ADVANCED=gpt-4o

# NestJS Backend (internal)
BACKEND_API_URL=http://localhost:3000/api/bot
BOT_API_KEY=your-secure-api-key-here

# Zalo OA
ZALO_OA_ID=your-oa-id
ZALO_OA_ACCESS_TOKEN=your-access-token
ZALO_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Facebook Messenger
FB_PAGE_ID=your-page-id
FB_PAGE_ACCESS_TOKEN=your-page-access-token
FB_APP_SECRET=your-app-secret
FB_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Session
SESSION_TTL_HOURS=24
