generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(map: "vector")]
}

// ── Enums ──────────────────────────────────────────────────

enum OrderStatus {
  PENDING       // Chờ xác nhận
  CONFIRMED     // Đã xác nhận
  PROCESSING    // Đang chuẩn bị
  SHIPPED       // Đang giao
  DELIVERED     // Đã giao
  CANCELLED     // Đã hủy
  REFUNDING     // Đang hoàn tiền
  REFUNDED      // Đã hoàn tiền
}

enum PaymentMethod {
  COD           // Thanh toán khi nhận hàng
  BANK_TRANSFER // Chuyển khoản
  MOMO          // Ví MoMo
  VNPAY         // VNPay
}

enum ChatPlatform {
  ZALO
  MESSENGER
  WEB
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum StockAuditStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum BatchStatus {
  ACTIVE        // Còn hàng, chưa hết hạn
  EXPIRED       // Đã hết hạn
  CONSUMED      // Đã sử dụng hết
  RECALLED      // Bị thu hồi
}

enum FulfillmentStrategy {
  FIFO          // First In First Out
  FEFO          // First Expired First Out
}

enum InventoryActionType {
  STOCK_IN
  STOCK_OUT
  STOCK_ADJUST
  STOCK_AUDIT
  STOCK_TRANSFER
  SUPPLIER_CREATE
  SUPPLIER_UPDATE
  SUPPLIER_ARCHIVE
  WAREHOUSE_CREATE
  WAREHOUSE_UPDATE
  BATCH_CREATE
  BATCH_EXPIRE
  BATCH_CONSUME
}

// ── Admin (thêm mới so với CLAUDE.md) ─────────────────────

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Category (thay thế enum ProductCategory) ──────────────

model Category {
  id                  String              @id @default(uuid())
  name                String              @unique
  slug                String              @unique
  description         String?
  image               String?
  isActive            Boolean             @default(true)
  fulfillmentStrategy FulfillmentStrategy @default(FIFO)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  products            Product[]
}

// ── Product ────────────────────────────────────────────────

model Product {
  id                  String              @id @default(uuid())
  name                String
  slug                String              @unique
  description         String
  shortDesc           String?
  price               Float
  salePrice           Float?
  categoryId          String
  category            Category            @relation(fields: [categoryId], references: [id])
  tags                String[]
  ingredients         String?
  nutritionInfo       Json?
  allergens           String[]
  origin              String?
  images              String[]
  stock               Int
  minStock            Int                 @default(10)
  sku                 String              @unique
  unit                String              @default("cái")
  isActive            Boolean             @default(true)
  isPublished         Boolean             @default(false)
  embeddedAt          DateTime?
  fulfillmentStrategy FulfillmentStrategy?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  orderItems          OrderItem[]
  embedding           ProductEmbedding?
  stockMovements      StockMovement[]
  warehouseStocks     WarehouseStock[]
  stockAuditItems     StockAuditItem[]
  stockTransfers      StockTransfer[]
  batches             ProductBatch[]
}

model Supplier {
  id            String          @id @default(uuid())
  name          String
  contactName   String?
  phone         String?
  email         String?
  address       String?
  note          String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  stockMovements StockMovement[]
  batches       ProductBatch[]
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  supplierId    String?
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  type          StockMovementType
  quantity      Int
  beforeStock   Int
  afterStock    Int
  unitCost      Float?
  reason        String?
  reference     String?
  batchId       String?
  batch         ProductBatch?     @relation(fields: [batchId], references: [id])
  createdAt     DateTime          @default(now())

  batchAllocations BatchStockMovement[]

  @@index([productId])
  @@index([supplierId])
  @@index([type])
  @@index([createdAt])
  @@index([batchId])
}

model Warehouse {
  id             String           @id @default(uuid())
  name           String
  code           String           @unique
  address        String?
  note           String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stocks         WarehouseStock[]
  audits         StockAudit[]
  transfersFrom  StockTransfer[]  @relation("TransferFromWarehouse")
  transfersTo    StockTransfer[]  @relation("TransferToWarehouse")
  batches        ProductBatch[]
}

model WarehouseStock {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  stock       Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([productId])
}

model StockAudit {
  id          String           @id @default(uuid())
  auditCode   String           @unique
  warehouseId String?
  warehouse   Warehouse?       @relation(fields: [warehouseId], references: [id])
  status      StockAuditStatus @default(DRAFT)
  note        String?
  createdBy   String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       StockAuditItem[]
}

model StockAuditItem {
  id           String     @id @default(uuid())
  auditId      String
  audit        StockAudit @relation(fields: [auditId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  systemStock  Int
  countedStock Int
  difference   Int
  note         String?

  @@index([auditId])
  @@index([productId])
}

model StockTransfer {
  id              String    @id @default(uuid())
  transferCode    String    @unique
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  quantity        Int
  reason          String?
  reference       String?
  createdAt       DateTime  @default(now())

  @@index([productId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

// ── ProductBatch (Lô hàng) ──────────────────────────────────

model ProductBatch {
  id              String       @id @default(uuid())
  batchCode       String       @unique
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  supplierId      String?
  supplier        Supplier?    @relation(fields: [supplierId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?   @relation(fields: [warehouseId], references: [id])
  initialQuantity Int
  remainingQty    Int
  unitCost        Float?
  receivedAt      DateTime     @default(now())
  expirationDate  DateTime?
  manufactureDate DateTime?
  status          BatchStatus  @default(ACTIVE)
  note            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  stockMovements  StockMovement[]
  orderItems      OrderItem[]
  batchAllocations BatchStockMovement[]

  @@index([productId])
  @@index([supplierId])
  @@index([warehouseId])
  @@index([status])
  @@index([expirationDate])
  @@index([receivedAt])
}

// ── BatchStockMovement (Phân bổ lô cho phiếu xuất) ──────────

model BatchStockMovement {
  id         String        @id @default(uuid())
  batchId    String
  batch      ProductBatch  @relation(fields: [batchId], references: [id])
  movementId String
  movement   StockMovement @relation(fields: [movementId], references: [id])
  quantity   Int

  @@unique([batchId, movementId])
  @@index([batchId])
  @@index([movementId])
}

model InventoryActionLog {
  id         String              @id @default(uuid())
  action     InventoryActionType
  entityType String
  entityId   String?
  message    String
  metadata   Json?
  createdBy  String?
  createdAt  DateTime            @default(now())

  @@index([action])
  @@index([createdAt])
}

// ── Product Embedding (pgvector) ────────────────────────────

model ProductEmbedding {
  id            String              @id @default(uuid())
  productId     String              @unique
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  embedding     Unsupported("vector(1536)")
  embeddingText String?             // Nội dung text gốc đã tạo embedding (debug)
  updatedAt     DateTime            @updatedAt
}

// ── Store Config ────────────────────────────────────────────

model StoreConfig {
  id        String   @id @default(uuid())
  key       String   @unique // "address", "phone", "open_hours", etc.
  value     String            // Giá trị (string hoặc JSON string)
  label     String?           // Tên hiển thị: "Địa chỉ cửa hàng"
  updatedAt DateTime @updatedAt
}

// ── Store Branch (chi nhánh) ───────────────────────────────

model StoreBranch {
  id         String   @id @default(uuid())
  name       String                    // "VegiFlow Quận 1"
  address    String                    // Địa chỉ đầy đủ
  phone      String?                   // SĐT riêng của chi nhánh
  email      String?                   // Email riêng
  openHours  Json?                     // {"mon": "8:00-21:00", ..., "sun": "9:00-18:00"}
  latitude   Float?
  longitude  Float?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)      // Thứ tự hiển thị
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Customer ───────────────────────────────────────────────

model Customer {
  id                String        @id @default(uuid())
  name              String
  phone             String        @unique
  email             String?
  address           String?
  shippingAddresses Json?
  tags              String[]      @default([])
  group             String        @default("REGULAR")
  note              String?
  passwordHash      String?                       // Mật khẩu (bcrypt) cho khách tự đăng ký trên storefront
  source            String        @default("ADMIN") // "ADMIN" (tạo bởi admin/chatbot) | "STOREFRONT" (khách tự đăng ký)
  orders            Order[]
  chatSessions      ChatSession[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
}

// ── Order + OrderItem ─────────────────────────────────────

model Order {
  id              String       @id @default(uuid())
  orderCode       String       @unique
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  totalAmount     Float
  discount        Float        @default(0)
  finalAmount     Float
  status          OrderStatus  @default(PENDING)
  shippingAddress String
  shippingPhone   String
  note            String?
  paymentMethod   PaymentMethod
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model OrderItem {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  batchId   String?
  batch     ProductBatch? @relation(fields: [batchId], references: [id])

  @@index([batchId])
}

// ── Chat Session + Message ─────────────────────────────────

model ChatSession {
  id              String        @id @default(uuid())
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  platform        ChatPlatform
  platformUserId  String
  guestPhone      String?
  cart            Json?         // Giỏ hàng tạm cho đặt hàng qua chatbot: [{ productId, quantity }]
  messages        ChatMessage[]
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([platform, platformUserId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      MessageRole
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())
}

// ── Email Report Config (cấu hình báo cáo định kỳ qua email) ──

model EmailReportConfig {
  id            String         @id @default(uuid())
  name          String                          // "Báo cáo ngày cho quản lý"
  recipients    String[]                        // ["manager@x.com", ...]
  intervalHours Int                             // Chu kỳ gửi (giờ): 1, 3, 5, 12, 24 ...
  sections      String[]                        // Mục nội dung — subset của SECTION_WHITELIST
  isActive      Boolean        @default(true)
  lastSentAt    DateTime?                       // Lần gửi cuối
  nextRunAt     DateTime       @default(now())  // Lần gửi kế tiếp — cột query cho cron tick
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  logs          EmailLog[]

  @@index([isActive, nextRunAt])
}

// ── Email Log (lịch sử gửi báo cáo) ──

model EmailLog {
  id             String            @id @default(uuid())
  reportConfig   EmailReportConfig @relation(fields: [reportConfigId], references: [id], onDelete: Cascade)
  reportConfigId String
  recipients     String[]                          // Snapshot người nhận lúc gửi
  subject        String
  status         String            @default("PENDING") // PENDING | SENT | FAILED
  error          String?                           // Message lỗi nếu FAILED
  sentAt         DateTime?
  payloadSummary Json?                             // Snapshot số liệu chính: { revenue, totalOrders, ... }
  createdAt      DateTime          @default(now())

  @@index([reportConfigId])
}
