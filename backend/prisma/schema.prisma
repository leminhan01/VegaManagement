generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────

enum OrderStatus {
  PENDING       // Chờ xác nhận
  CONFIRMED     // Đã xác nhận
  PROCESSING    // Đang chuẩn bị
  SHIPPED       // Đang giao
  DELIVERED     // Đã giao
  CANCELLED     // Đã hủy
  REFUNDING     // Đang hoàn tiền
  REFUNDED      // Đã hoàn tiền
}

enum PaymentMethod {
  COD           // Thanh toán khi nhận hàng
  BANK_TRANSFER // Chuyển khoản
  MOMO          // Ví MoMo
  VNPAY         // VNPay
}

enum ChatPlatform {
  ZALO
  MESSENGER
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum StockAuditStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum BatchStatus {
  ACTIVE        // Còn hàng, chưa hết hạn
  EXPIRED       // Đã hết hạn
  CONSUMED      // Đã sử dụng hết
  RECALLED      // Bị thu hồi
}

enum FulfillmentStrategy {
  FIFO          // First In First Out
  FEFO          // First Expired First Out
}

enum InventoryActionType {
  STOCK_IN
  STOCK_OUT
  STOCK_ADJUST
  STOCK_AUDIT
  STOCK_TRANSFER
  SUPPLIER_CREATE
  SUPPLIER_UPDATE
  SUPPLIER_ARCHIVE
  WAREHOUSE_CREATE
  WAREHOUSE_UPDATE
  BATCH_CREATE
  BATCH_EXPIRE
  BATCH_CONSUME
}

// ── Admin (thêm mới so với CLAUDE.md) ─────────────────────

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Category (thay thế enum ProductCategory) ──────────────

model Category {
  id                  String              @id @default(uuid())
  name                String              @unique
  slug                String              @unique
  description         String?
  image               String?
  isActive            Boolean             @default(true)
  fulfillmentStrategy FulfillmentStrategy @default(FIFO)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  products            Product[]
}

// ── Product ────────────────────────────────────────────────

model Product {
  id                  String              @id @default(uuid())
  name                String
  slug                String              @unique
  description         String
  shortDesc           String?
  price               Float
  salePrice           Float?
  categoryId          String
  category            Category            @relation(fields: [categoryId], references: [id])
  tags                String[]
  ingredients         String?
  nutritionInfo       Json?
  allergens           String[]
  origin              String?
  images              String[]
  stock               Int
  minStock            Int                 @default(10)
  sku                 String              @unique
  unit                String              @default("cái")
  isActive            Boolean             @default(true)
  fulfillmentStrategy FulfillmentStrategy?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  orderItems          OrderItem[]
  stockMovements      StockMovement[]
  warehouseStocks     WarehouseStock[]
  stockAuditItems     StockAuditItem[]
  stockTransfers      StockTransfer[]
  batches             ProductBatch[]
}

model Supplier {
  id            String          @id @default(uuid())
  name          String
  contactName   String?
  phone         String?
  email         String?
  address       String?
  note          String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  stockMovements StockMovement[]
  batches       ProductBatch[]
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  supplierId    String?
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])
  type          StockMovementType
  quantity      Int
  beforeStock   Int
  afterStock    Int
  unitCost      Float?
  reason        String?
  reference     String?
  batchId       String?
  batch         ProductBatch?     @relation(fields: [batchId], references: [id])
  createdAt     DateTime          @default(now())

  batchAllocations BatchStockMovement[]

  @@index([productId])
  @@index([supplierId])
  @@index([type])
  @@index([createdAt])
  @@index([batchId])
}

model Warehouse {
  id             String           @id @default(uuid())
  name           String
  code           String           @unique
  address        String?
  note           String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stocks         WarehouseStock[]
  audits         StockAudit[]
  transfersFrom  StockTransfer[]  @relation("TransferFromWarehouse")
  transfersTo    StockTransfer[]  @relation("TransferToWarehouse")
  batches        ProductBatch[]
}

model WarehouseStock {
  id          String    @id @default(uuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  stock       Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@index([productId])
}

model StockAudit {
  id          String           @id @default(uuid())
  auditCode   String           @unique
  warehouseId String?
  warehouse   Warehouse?       @relation(fields: [warehouseId], references: [id])
  status      StockAuditStatus @default(DRAFT)
  note        String?
  createdBy   String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       StockAuditItem[]
}

model StockAuditItem {
  id           String     @id @default(uuid())
  auditId      String
  audit        StockAudit @relation(fields: [auditId], references: [id])
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  systemStock  Int
  countedStock Int
  difference   Int
  note         String?

  @@index([auditId])
  @@index([productId])
}

model StockTransfer {
  id              String    @id @default(uuid())
  transferCode    String    @unique
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  quantity        Int
  reason          String?
  reference       String?
  createdAt       DateTime  @default(now())

  @@index([productId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

// ── ProductBatch (Lô hàng) ──────────────────────────────────

model ProductBatch {
  id              String       @id @default(uuid())
  batchCode       String       @unique
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  supplierId      String?
  supplier        Supplier?    @relation(fields: [supplierId], references: [id])
  warehouseId     String?
  warehouse       Warehouse?   @relation(fields: [warehouseId], references: [id])
  initialQuantity Int
  remainingQty    Int
  unitCost        Float?
  receivedAt      DateTime     @default(now())
  expirationDate  DateTime?
  manufactureDate DateTime?
  status          BatchStatus  @default(ACTIVE)
  note            String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  stockMovements  StockMovement[]
  orderItems      OrderItem[]
  batchAllocations BatchStockMovement[]

  @@index([productId])
  @@index([supplierId])
  @@index([warehouseId])
  @@index([status])
  @@index([expirationDate])
  @@index([receivedAt])
}

// ── BatchStockMovement (Phân bổ lô cho phiếu xuất) ──────────

model BatchStockMovement {
  id         String        @id @default(uuid())
  batchId    String
  batch      ProductBatch  @relation(fields: [batchId], references: [id])
  movementId String
  movement   StockMovement @relation(fields: [movementId], references: [id])
  quantity   Int

  @@unique([batchId, movementId])
  @@index([batchId])
  @@index([movementId])
}

model InventoryActionLog {
  id         String              @id @default(uuid())
  action     InventoryActionType
  entityType String
  entityId   String?
  message    String
  metadata   Json?
  createdBy  String?
  createdAt  DateTime            @default(now())

  @@index([action])
  @@index([createdAt])
}

// ── Customer ───────────────────────────────────────────────

model Customer {
  id           String        @id @default(uuid())
  name         String
  phone        String        @unique
  email        String?
  address      String?
  orders       Order[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
}

// ── Order + OrderItem ─────────────────────────────────────

model Order {
  id              String       @id @default(uuid())
  orderCode       String       @unique
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  totalAmount     Float
  discount        Float        @default(0)
  finalAmount     Float
  status          OrderStatus  @default(PENDING)
  shippingAddress String
  shippingPhone   String
  note            String?
  paymentMethod   PaymentMethod
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model OrderItem {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  batchId   String?
  batch     ProductBatch? @relation(fields: [batchId], references: [id])

  @@index([batchId])
}

// ── Chat Session + Message ─────────────────────────────────

model ChatSession {
  id              String        @id @default(uuid())
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  platform        ChatPlatform
  platformUserId  String
  guestPhone      String?
  messages        ChatMessage[]
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([platform, platformUserId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      MessageRole
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())
}
