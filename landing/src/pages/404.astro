---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Không tìm thấy trang | VegiFlow">
  <main id="main-content" class="error-page">
    <div class="container error-inner">
      <p class="error-eyebrow">404</p>
      <h1 class="error-title text-balance">Không tìm thấy trang</h1>
      <p class="error-desc text-pretty">
        Trang bạn đang tìm kiếm có thể đã bị xóa, di chuyển, hoặc không tồn tại.
      </p>
      <div class="error-actions">
        <a href="/" class="error-btn-primary">← Về trang chủ</a>
        <button class="error-btn-ghost" id="error-chat-btn">
          Chat với chúng tôi
        </button>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  (function () {
    var btn = document.getElementById('error-chat-btn');
    if (btn) {
      btn.addEventListener('click', function () {
        // Chat widget might not be on this page, redirect to home with chat
        window.location.href = '/#chat';
      });
    }
  })();
</script>

<style>
  .error-page {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-block: var(--space-5xl);
  }

  .error-inner {
    max-width: 480px;
  }

  .error-eyebrow {
    font-size: 6rem;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: var(--space-lg);
    letter-spacing: -0.04em;
  }

  .error-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: var(--color-deep);
    margin-bottom: var(--space-md);
    letter-spacing: var(--ls-tight);
  }

  .error-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-2xl);
  }

  .error-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .error-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    background: var(--color-primary);
    color: #fff;
    font-size: var(--text-small);
    font-weight: 600;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background var(--duration-fast) ease, transform var(--duration-fast) ease;
  }

  .error-btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    color: #fff;
    text-decoration: none;
  }

  .error-btn-ghost {
    padding: var(--space-md) var(--space-xl);
    color: var(--color-text-secondary);
    font-size: var(--text-small);
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: color var(--duration-fast) ease, border-color var(--duration-fast) ease;
  }

  .error-btn-ghost:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }
</style>
