---
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-blob" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-eyebrow reveal">
        <i class="ph ph-leaf" aria-hidden="true"></i>
        Thực phẩm chay online
      </p>

      <h1 id="hero-title" class="hero-title text-balance reveal reveal-delay-1">
        Ăn chay dễ dàng,<br />
        <span class="hero-highlight">tươi sạch</span> trong tầm tay
      </h1>

      <p class="hero-subtitle text-pretty reveal reveal-delay-2">
        Hơn 100 sản phẩm organic, rau tươi, hạt khô và đông lạnh. Tư vấn miễn
        phí, giao nội thành TP.HCM trong 2 giờ.
      </p>

      <div class="hero-actions reveal reveal-delay-3">
        <button class="btn-primary" id="hero-chat-btn">
          <i class="ph ph-chat-circle" aria-hidden="true"></i>
          Chat tư vấn ngay
        </button>
        <a href="#categories" class="btn-ghost">
          Xem sản phẩm
          <i class="ph ph-arrow-right btn-arrow" aria-hidden="true"></i>
        </a>
      </div>
    </div>

    <div class="hero-visual reveal reveal-delay-2">
      <div class="hero-photo">
        <img
          src="https://picsum.photos/seed/vegiflow-bowl-fresh/900/1100"
          alt="Món salad rau củ tươi sạch của VegiFlow"
          loading="eager"
          width="900"
          height="1100"
        />
      </div>

      <div class="hero-card hero-card-rating" aria-hidden="false">
        <div class="hero-stars" aria-label="Đánh giá 4,9 trên 5 sao">
          <i class="ph ph-star"></i><i class="ph ph-star"></i
          ><i class="ph ph-star"></i><i class="ph ph-star"></i
          ><i class="ph ph-star"></i>
        </div>
        <div class="hero-card-meta">
          <strong>4,9 / 5</strong>
          <span>1.200+ khách hàng</span>
        </div>
      </div>

      <div class="hero-card hero-card-delivery">
        <span class="hero-card-icon" aria-hidden="true"><i class="ph ph-truck"></i></span>
        <div class="hero-card-text">
          <strong>Giao trong 2 giờ</strong>
          <span>Nội thành, freeship 300k</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('hero-chat-btn').addEventListener('click', function () {
    var chatBtn = document.querySelector('.vf-chat-btn');
    if (chatBtn) chatBtn.click();
  });
</script>

<style>
  .hero {
    position: relative;
    padding-block: var(--space-3xl) var(--space-5xl);
    overflow: hidden;
  }

  .hero-blob {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(
        ellipse 55% 60% at 78% 28%,
        rgba(34, 166, 90, 0.14),
        transparent 60%
      ),
      radial-gradient(
        ellipse 45% 50% at 12% 70%,
        rgba(20, 83, 45, 0.07),
        transparent 65%
      );
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  /* ── Copy column ─────────────────────────── */
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-primary);
    background: var(--color-primary-muted);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-xl);
    letter-spacing: var(--ls-wide);
  }

  .hero-eyebrow i {
    font-size: 1rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.2vw, 4.25rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: var(--ls-tight);
    color: var(--color-deep);
    margin-bottom: var(--space-xl);
  }

  .hero-highlight {
    position: relative;
    color: var(--color-primary);
    white-space: nowrap;
  }

  .hero-highlight::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 0.28em;
    background: rgba(34, 166, 90, 0.18);
    border-radius: 999px;
    z-index: -1;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 400;
    line-height: var(--lh-relaxed);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-bottom: var(--space-2xl);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-2xl);
    background: var(--color-primary);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    box-shadow: 0 8px 24px rgba(34, 166, 90, 0.32);
    transition:
      background var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-spring),
      box-shadow var(--duration-normal) ease;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(34, 166, 90, 0.4);
    color: #fff;
  }

  .btn-primary:active {
    transform: scale(0.98) translateY(0);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-deep);
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-full);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition:
      color var(--duration-fast) ease,
      background var(--duration-fast) ease,
      border-color var(--duration-fast) ease;
  }

  .btn-ghost:hover {
    color: var(--color-primary);
    background: var(--color-primary-muted);
    border-color: var(--color-primary-light);
    text-decoration: none;
  }

  .btn-arrow {
    transition: transform var(--duration-fast) ease;
  }

  .btn-ghost:hover .btn-arrow {
    transform: translateX(4px);
  }

  /* ── Visual column ───────────────────────── */
  .hero-visual {
    position: relative;
    aspect-ratio: 5 / 6;
    max-width: 460px;
    margin-left: auto;
    width: 100%;
  }

  .hero-photo {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow:
      0 30px 60px -20px rgba(20, 83, 45, 0.35),
      0 12px 24px -12px rgba(20, 83, 45, 0.2);
    background: var(--color-primary-light);
  }

  .hero-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.5);
    pointer-events: none;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Floating cards */
  .hero-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: var(--space-md) var(--space-lg);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 14px 36px -12px rgba(20, 83, 45, 0.28);
  }

  .hero-card-rating {
    top: 8%;
    left: -8%;
  }

  .hero-card-delivery {
    bottom: 10%;
    right: -6%;
  }

  .hero-stars {
    display: flex;
    gap: 1px;
    color: #f5a623;
    font-size: 0.95rem;
  }

  .hero-card-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .hero-card-meta strong {
    font-size: var(--text-small);
    color: var(--color-deep);
  }

  .hero-card-meta span {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .hero-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    font-size: 1.2rem;
    color: #fff;
    background: var(--color-primary);
    border-radius: 12px;
    flex-shrink: 0;
  }

  .hero-card-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }

  .hero-card-text strong {
    font-size: var(--text-small);
    color: var(--color-deep);
  }

  .hero-card-text span {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
    }

    .hero-visual {
      max-width: 380px;
      margin-inline: auto;
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: clamp(2rem, 8vw, 2.6rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary,
    .btn-ghost {
      justify-content: center;
    }

    .hero-card-rating {
      left: -2%;
      top: 4%;
    }

    .hero-card-delivery {
      right: -2%;
      bottom: 4%;
    }

    .hero-card {
      padding: var(--space-sm) var(--space-md);
    }

    .hero-card-icon {
      width: 32px;
      height: 32px;
      font-size: 1rem;
    }
  }

  @media (max-width: 380px) {
    .hero-card-meta span,
    .hero-card-text span {
      display: none;
    }
  }
</style>
