---
---

<section class="cta" aria-labelledby="cta-title">
  <div class="cta-noise" aria-hidden="true"></div>
  <div class="container cta-inner">
    <div class="cta-content reveal">
      <h2 id="cta-title" class="cta-title text-balance">
        Sẵn sàng khám phá<br />thực phẩm chay?
      </h2>
      <p class="cta-subtitle text-pretty">
        Chat với AI assistant để được tư vấn sản phẩm phù hợp nhất cho bạn
      </p>
      <button class="cta-btn" id="cta-chat-btn">
        <span aria-hidden="true">🌿</span>
        Bắt đầu chat ngay
      </button>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('cta-chat-btn').addEventListener('click', function () {
    var chatBtn = document.querySelector('.vf-chat-btn');
    if (chatBtn) chatBtn.click();
  });
</script>

<style>
  .cta {
    position: relative;
    padding-block: var(--space-5xl);
    overflow: hidden;
    background: radial-gradient(
      ellipse 80% 80% at 50% 40%,
      #166534 0%,
      #14532d 40%,
      #0a2e18 100%
    );
  }

  .cta-noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  .cta-inner {
    display: flex;
    justify-content: center;
    text-align: center;
  }

  .cta-content {
    max-width: 560px;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    color: #fff;
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-md);
  }

  .cta-subtitle {
    font-size: var(--text-body);
    color: rgba(255, 255, 255, 0.75);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-2xl);
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-2xl);
    background: #fff;
    color: var(--color-deep);
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    transition:
      transform var(--duration-fast) ease,
      box-shadow var(--duration-normal) ease;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  }

  .cta-btn:active {
    transform: scale(0.98) translateY(0);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 640px) {
    .cta {
      padding-block: var(--space-4xl);
    }

    .cta-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
