---
---

<section class="cta-wrap" aria-labelledby="cta-title">
  <div class="container">
    <div class="cta-panel reveal">
      <div class="cta-noise" aria-hidden="true"></div>
      <div class="cta-glow" aria-hidden="true"></div>

      <div class="cta-content">
        <p class="cta-eyebrow">
          <i class="ph ph-chat-circle-dots" aria-hidden="true"></i>
          Tư vấn miễn phí
        </p>
        <h2 id="cta-title" class="cta-title text-balance">
          Sẵn sàng khám phá thực phẩm chay?
        </h2>
        <p class="cta-subtitle text-pretty">
          Chat với trợ lý tư vấn để tìm ngay món phù hợp với bạn, đặt đơn dễ dàng trong vài phút.
        </p>
        <div class="cta-actions">
          <button class="cta-btn" id="cta-chat-btn">
            <i class="ph ph-chat-circle" aria-hidden="true"></i>
            Bắt đầu chat ngay
          </button>
          <a href="tel:+84901234567" class="cta-call">
            <i class="ph ph-phone" aria-hidden="true"></i>
            Gọi 0901 234 567
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('cta-chat-btn').addEventListener('click', function () {
    var chatBtn = document.querySelector('.vf-chat-btn');
    if (chatBtn) chatBtn.click();
  });
</script>

<style>
  .cta-wrap {
    padding-block: var(--space-5xl);
  }
 
  .cta-panel {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    padding: clamp(var(--space-3xl), 7vw, var(--space-5xl)) var(--container-padding);
    text-align: center;
    background: linear-gradient(150deg, #1a7a44 0%, #14532d 55%, #0f3d20 100%);
    box-shadow: 0 40px 80px -32px rgba(15, 61, 32, 0.5);
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 60% 70% at 50% 0%,
      rgba(255, 255, 255, 0.12),
      transparent 60%
    );
    pointer-events: none;
  }

  .cta-noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.05;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  .cta-content {
    position: relative;
    max-width: 600px;
    margin-inline: auto;
  }

  .cta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-small);
    font-weight: 600;
    color: #d1fae5;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-lg);
  }

  .cta-eyebrow i {
    font-size: 1rem;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4vw, var(--text-h2));
    font-weight: 700;
    color: #fff;
    letter-spacing: var(--ls-tight);
    margin-bottom: var(--space-md);
    line-height: 1.15;
  }

  .cta-subtitle {
    font-size: var(--text-body);
    color: rgba(255, 255, 255, 0.78);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-2xl);
    margin-inline: auto;
    max-width: 460px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-2xl);
    background: #fff;
    color: var(--color-deep);
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    box-shadow: 0 10px 28px -8px rgba(0, 0, 0, 0.3);
    transition:
      transform var(--duration-fast) var(--ease-spring),
      box-shadow var(--duration-normal) ease;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px -8px rgba(0, 0, 0, 0.35);
  }

  .cta-btn:active {
    transform: scale(0.98) translateY(0);
  }

  .cta-call {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.35);
    transition:
      background var(--duration-fast) ease,
      border-color var(--duration-fast) ease;
  }

  .cta-call:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.55);
    color: #fff;
    text-decoration: none;
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 560px) {
    .cta-actions {
      flex-direction: column;
    }

    .cta-btn,
    .cta-call {
      width: 100%;
      justify-content: center;
    }
  }
</style>
