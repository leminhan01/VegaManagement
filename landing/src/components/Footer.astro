---
const currentYear = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="VegiFlow, trang chủ">
          <span class="footer-logo-mark" aria-hidden="true"><i class="ph ph-leaf"></i></span>
          <span class="footer-logo-name">VegiFlow</span>
        </a>
        <p class="footer-tagline">
          Cửa hàng thực phẩm chay online, tư vấn tận tâm, giao hàng tận nơi trên khắp TP.HCM.
        </p>
        <div class="footer-social" aria-label="Mạng xã hội">
          <a href="https://zalo.me" class="footer-social-link" aria-label="Zalo" rel="noopener" target="_blank">
            <i class="ph ph-chat-circle-dots"></i>
          </a>
          <a href="https://facebook.com" class="footer-social-link" aria-label="Facebook" rel="noopener" target="_blank">
            <i class="ph ph-facebook-logo"></i>
          </a>
          <a href="https://instagram.com" class="footer-social-link" aria-label="Instagram" rel="noopener" target="_blank">
            <i class="ph ph-instagram-logo"></i>
          </a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Liên kết chân trang">
        <div class="footer-nav-group">
          <h3 class="footer-nav-title">Khám phá</h3>
          <ul class="footer-nav-links" role="list">
            <li><a href="/#categories">Danh mục sản phẩm</a></li>
            <li><a href="/#features">Dịch vụ</a></li>
            <li><a href="/#categories">Sản phẩm mới</a></li>
          </ul>
        </div>
        <div class="footer-nav-group">
          <h3 class="footer-nav-title">Liên hệ</h3>
          <ul class="footer-nav-links footer-contact" role="list">
            <li>
              <i class="ph ph-map-pin" aria-hidden="true"></i>
              <span>123 Lê Lợi, Q.1, TP.HCM</span>
            </li>
            <li>
              <i class="ph ph-phone" aria-hidden="true"></i>
              <a href="tel:+84901234567">0901 234 567</a>
            </li>
            <li>
              <i class="ph ph-envelope-simple" aria-hidden="true"></i>
              <a href="mailto:hello@vegiflow.vn">hello@vegiflow.vn</a>
            </li>
            <li>
              <i class="ph ph-clock" aria-hidden="true"></i>
              <span>7:00 - 21:00 hằng ngày</span>
            </li>
          </ul>
        </div>
        <div class="footer-nav-group">
          <h3 class="footer-nav-title">Pháp lý</h3>
          <ul class="footer-nav-links" role="list">
            <li><a href="/privacy">Chính sách bảo mật</a></li>
            <li><a href="/terms">Điều khoản sử dụng</a></li>
            <li><a href="/shipping">Chính sách giao hàng</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {currentYear} <a href="/">VegiFlow</a>. Mọi quyền được bảo lưu.
      </p>
      <p class="footer-note">Ăn chay, sống khỏe, vì một hành tinh xanh.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #15140f;
    color: rgba(255, 255, 255, 0.6);
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-2xl);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: var(--space-3xl);
  }

  /* Brand */
  .footer-brand {
    max-width: 340px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    margin-bottom: var(--space-md);
  }

  .footer-logo:hover {
    color: #fff;
  }

  .footer-logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    font-size: 1rem;
    color: #fff;
    background: linear-gradient(140deg, var(--color-primary), var(--color-deep));
    border-radius: 9px;
  }

  .footer-logo-name {
    letter-spacing: var(--ls-tight);
  }

  .footer-tagline {
    font-size: var(--text-small);
    line-height: var(--lh-body);
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-lg);
  }

  .footer-social {
    display: flex;
    gap: var(--space-sm);
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    transition:
      color var(--duration-fast) ease,
      background var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-spring);
  }

  .footer-social-link:hover {
    color: #fff;
    background: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-2px);
    text-decoration: none;
  }

  /* Nav */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
  }

  .footer-nav-title {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-md);
  }

  .footer-nav-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer-nav-links a {
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer-nav-links a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .footer-contact li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.55);
  }

  .footer-contact i {
    font-size: 1rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .footer-contact li a {
    color: rgba(255, 255, 255, 0.55);
  }

  /* Bottom */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-copy a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }

  .footer-copy a:hover {
    color: var(--color-primary);
  }

  .footer-note {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.35);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 820px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .footer-nav {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
