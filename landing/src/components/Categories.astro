---
const categories = [
  { icon: 'ph-carrot', title: 'Thực phẩm tươi', desc: 'Rau củ, trái cây sạch', image: 'https://picsum.photos/seed/veg-fresh-greens/700/700', span: 'wide' },
  { icon: 'ph-plant', title: 'Thực phẩm khô', desc: 'Hạt, đậu, nấm khô', image: 'https://picsum.photos/seed/veg-dried-beans/600/600' },
  { icon: 'ph-cooking-pot', title: 'Gia vị', desc: 'Nước mắm chay, tương', image: 'https://picsum.photos/seed/veg-spice-pot/600/600' },
  { icon: 'ph-snowflake', title: 'Đông lạnh', desc: 'Thịt thực vật, há cảo', image: 'https://picsum.photos/seed/veg-frozen-dumpling/600/600' },
  { icon: 'ph-coffee', title: 'Đồ uống', desc: 'Trà, nước ép, sinh tố', image: 'https://picsum.photos/seed/veg-drink-tea/600/600' },
  { icon: 'ph-cookie', title: 'Đồ ăn vặt', desc: 'Snack chay, hạt rang', image: 'https://picsum.photos/seed/veg-snack-nuts/600/600' },
  { icon: 'ph-pill', title: 'Bổ sung', desc: 'Vitamin, protein thực vật', image: 'https://picsum.photos/seed/veg-supplement/600/600' },
  { icon: 'ph-bowl-food', title: 'Món ăn sẵn', desc: 'Đồ hộp, mì chay', image: 'https://picsum.photos/seed/veg-ready-meal/700/700', span: 'wide' },
];
---

<section class="categories" id="categories" aria-labelledby="categories-title">
  <div class="container">
    <header class="section-header reveal">
      <h2 id="categories-title" class="section-title text-balance">Danh mục sản phẩm</h2>
      <p class="section-desc text-pretty">Đa dạng thực phẩm chay cho mọi bữa ăn, từ bếp nhà đến bàn tiệc.</p>
    </header>

    <div class="categories-grid" id="vf-landing-categories">
      {categories.map((cat, i) => (
        <article
          class:list={[
            'category-card',
            'reveal',
            `reveal-delay-${(i % 4) + 1}`,
            { 'category-card--wide': cat.span === 'wide' },
          ]}
        >
          <div class="category-image" aria-hidden="true">
            <img src={cat.image} alt="" loading="lazy" />
          </div>
          <div class="category-overlay" aria-hidden="true"></div>
          <div class="category-content">
            <span class="category-icon" aria-hidden="true">
              <i class={`ph ${cat.icon}`}></i>
            </span>
            <div class="category-meta">
              <h3 class="category-title">{cat.title}</h3>
              <p class="category-desc">{cat.desc}</p>
            </div>
            <span class="category-arrow" aria-hidden="true"><i class="ph ph-arrow-up-right"></i></span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .categories {
    padding-block: var(--space-section);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: var(--ls-tight);
    color: var(--color-deep);
    margin-bottom: var(--space-sm);
  }

  .section-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-inline: auto;
  }

  /* ── Grid ───────────────────────────────── */
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  /* ── Card ───────────────────────────────── */
  .category-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 1;
    cursor: pointer;
    background: var(--color-deep);
    border: 0;
    width: 100%;
    font: inherit;
    text-align: left;
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out);
  }

  .category-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 22px 44px -18px rgba(20, 83, 45, 0.4);
  }

  .category-card:active {
    transform: scale(0.98) translateY(0);
  }

  .category-card:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 4px;
  }

  .category-card.is-active {
    box-shadow: 0 0 0 3px var(--color-primary), 0 22px 44px -18px rgba(20, 83, 45, 0.4);
  }

  .category-card--wide {
    grid-column: span 2;
    aspect-ratio: 2 / 1;
  }

  .category-image {
    position: absolute;
    inset: 0;
  }

  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .category-card:hover .category-image img {
    transform: scale(1.07);
  }

  .category-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(15, 61, 32, 0.05) 0%,
      rgba(15, 61, 32, 0.45) 55%,
      rgba(15, 61, 32, 0.78) 100%
    );
    transition: background var(--duration-normal) ease;
  }

  .category-card:hover .category-overlay {
    background: linear-gradient(
      180deg,
      rgba(15, 61, 32, 0.1) 0%,
      rgba(15, 61, 32, 0.55) 50%,
      rgba(15, 61, 32, 0.88) 100%
    );
  }

  .category-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    gap: var(--space-md);
    padding: var(--space-lg);
    color: #fff;
  }

  .category-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    font-size: 1.3rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 11px;
    flex-shrink: 0;
  }

  .category-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
  }

  .category-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 2px;
    letter-spacing: var(--ls-tight);
  }

  .category-desc {
    font-size: var(--text-xs);
    opacity: 0.82;
    font-weight: 400;
  }

  .category-arrow {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    font-size: 1rem;
    color: #fff;
    background: var(--color-primary);
    border-radius: 50%;
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity var(--duration-normal) ease,
      transform var(--duration-normal) var(--ease-out);
    align-self: center;
  }

  .category-card:hover .category-arrow {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 900px) {
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .category-card--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 540px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }

    .category-card--wide {
      grid-column: span 1;
      aspect-ratio: 16 / 9;
    }

    .category-card {
      aspect-ratio: 4 / 3;
    }
  }
</style>
