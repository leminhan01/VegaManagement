---
---

<nav class="nav" role="navigation" aria-label="Menu chính">
  <div class="container nav-inner">
    <a href="/" class="nav-brand" aria-label="VegiFlow, trang chủ">
      <span class="nav-logo" aria-hidden="true"><i class="ph ph-leaf"></i></span>
      <span class="nav-name">VegiFlow</span>
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#categories" class="nav-link">Danh mục</a></li>
      <li><a href="#features" class="nav-link">Dịch vụ</a></li>
      <li>
        <a href="tel:+84901234567" class="nav-link nav-hotline">
          <i class="ph ph-phone" aria-hidden="true"></i>
          <span>Hotline</span>
        </a>
      </li>
      <li id="vf-nav-account"><!-- storefront.js inject nút tài khoản --></li>
      <li>
        <button class="nav-chat-btn" id="nav-chat-btn" aria-label="Mở chat tư vấn">
          <i class="ph ph-chat-circle" aria-hidden="true"></i>
          Chat ngay
        </button>
      </li>
    </ul>

    <button class="nav-hamburger" id="nav-hamburger" aria-label="Mở menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <ul class="nav-mobile-links" role="list">
      <li><a href="#categories" class="nav-mobile-link">Danh mục</a></li>
      <li><a href="#features" class="nav-mobile-link">Dịch vụ</a></li>
      <li>
        <a href="tel:+84901234567" class="nav-mobile-link">
          <i class="ph ph-phone" aria-hidden="true"></i> Hotline
        </a>
      </li>
      <li>
        <button class="nav-mobile-chat" id="nav-mobile-chat">
          <i class="ph ph-chat-circle" aria-hidden="true"></i> Chat ngay
        </button>
      </li>
    </ul>
  </div>
</nav>

<!-- Spacer for fixed nav -->
<div class="nav-spacer"></div>

<script is:inline>
  (function () {
    const hamburger = document.getElementById('nav-hamburger');
    const mobile = document.getElementById('nav-mobile');
    const navChatBtn = document.getElementById('nav-chat-btn');
    const navMobileChat = document.getElementById('nav-mobile-chat');

    function openChat() {
      const chatBtn = document.querySelector('.vf-chat-btn');
      if (chatBtn) chatBtn.click();
    }

    function toggleMenu() {
      const isOpen = mobile.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
      mobile.setAttribute('aria-hidden', String(!isOpen));
    }

    function closeMenu() {
      mobile.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobile.setAttribute('aria-hidden', 'true');
    }

    hamburger.addEventListener('click', toggleMenu);
    navChatBtn.addEventListener('click', openChat);
    if (navMobileChat)
      navMobileChat.addEventListener('click', function () {
        closeMenu();
        openChat();
      });

    mobile.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });

    // Nav background on scroll via IntersectionObserver (no scroll listener)
    const nav = document.querySelector('.nav');
    const sentinel = document.querySelector('.nav-sentinel');
    if (nav && sentinel && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        function (entries) {
          nav.classList.toggle('scrolled', !entries[0].isIntersecting);
        },
        { rootMargin: '0px 0px 0px 0px', threshold: 0 }
      );
      io.observe(sentinel);
    } else if (nav) {
      nav.classList.add('scrolled');
    }
  })();
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    background: rgba(250, 249, 247, 0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition:
      background var(--duration-normal) ease,
      backdrop-filter var(--duration-normal) ease,
      box-shadow var(--duration-normal) ease,
      border-color var(--duration-normal) ease;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: rgba(250, 249, 247, 0.85);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom-color: var(--color-border-light);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  /* Brand */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-deep);
    text-decoration: none;
  }

  .nav-brand:hover {
    color: var(--color-deep);
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    font-size: 1.1rem;
    color: #fff;
    background: linear-gradient(140deg, var(--color-primary), var(--color-deep));
    border-radius: 10px;
    box-shadow: 0 4px 12px rgba(34, 166, 90, 0.3);
  }

  .nav-name {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: var(--ls-tight);
  }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    list-style: none;
  }

  .nav-link {
    position: relative;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-xs) 0;
    transition: color var(--duration-fast) ease;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
    transition: width var(--duration-normal) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--color-deep);
    text-decoration: none;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-hotline i {
    font-size: 1rem;
    color: var(--color-primary);
  }

  /* Chat button */
  .nav-chat-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-small);
    font-weight: 600;
    color: #fff;
    background: var(--color-primary);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-full);
    box-shadow: 0 4px 14px rgba(34, 166, 90, 0.28);
    transition:
      background var(--duration-fast) ease,
      transform var(--duration-fast) var(--ease-spring),
      box-shadow var(--duration-fast) ease;
  }

  .nav-chat-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(34, 166, 90, 0.36);
  }

  .nav-chat-btn:active {
    transform: scale(0.97) translateY(0);
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-sm);
    cursor: pointer;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition:
      transform var(--duration-normal) ease,
      opacity var(--duration-fast) ease;
  }

  .nav-hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */
  .nav-mobile {
    display: none;
    flex-direction: column;
    background: rgba(250, 249, 247, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    padding: var(--space-lg) var(--container-padding) var(--space-2xl);
    border-top: 1px solid var(--color-border-light);
  }

  .nav-mobile.open {
    display: flex;
    animation: slideDown var(--duration-normal) var(--ease-out);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    list-style: none;
  }

  .nav-mobile-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-sm) 0;
  }

  .nav-mobile-link:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-mobile-chat {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-size: var(--text-body);
    font-weight: 600;
    color: #fff;
    background: var(--color-primary);
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-full);
    text-align: center;
    margin-top: var(--space-md);
    transition: background var(--duration-fast) ease;
  }

  .nav-mobile-chat:hover {
    background: var(--color-primary-hover);
  }

  /* Spacer */
  .nav-spacer {
    height: 68px;
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 820px) {
    .nav-links {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>
