---
const featured = [
  {
    icon: 'ph-sparkle',
    title: 'Trợ lý tư vấn cá nhân hóa',
    desc: 'Chat với trợ lý ảo để được gợi ý món phù hợp sở thích, chế độ dinh dưỡng và ngân sách của bạn, hoàn toàn miễn phí.',
    image: 'https://res.cloudinary.com/draoz2f7p/image/upload/v1783548436/chatbot_vegi_jjxlb2.png',
    points: ['Hiểu khẩu vị của bạn', 'Gợi ý món theo ngân sách', 'Tra cứu đơn hàng tức thì'],
  },
  {
    icon: 'ph-truck',
    title: 'Giao hàng siêu tốc',
    desc: 'Giao nội thành TP.HCM trong 2 đến 4 giờ, đóng gói cẩn thận giữ trọn độ tươi. Freeship cho đơn từ 300.000đ.',
    image: 'https://res.cloudinary.com/draoz2f7p/image/upload/v1783548190/shipping_ay44il.png',
    points: ['Giao 2-4h nội thành', 'Freeship đơn từ 300k', 'Đổi trả trong 7 ngày'],
  },
];

const more = [
  {
    icon: 'ph-chats',
    title: 'Chat mọi nền tảng',
    desc: 'Nhắn tin qua Zalo, Facebook Messenger hoặc web, bất cứ lúc nào.',
  },
  {
    icon: 'ph-seal-check',
    title: 'Nguồn gốc rõ ràng',
    desc: 'Mỗi sản phẩm đều ghi rõ thành phần, chứng nhận VietGAP và Organic.',
  },
  {
    icon: 'ph-arrow-counter-clockwise',
    title: 'Đổi trả 7 ngày',
    desc: 'Không vừa ý? Đổi trả trong 7 ngày, hoàn tiền nhanh chóng.',
  },
];
---

<section class="features" id="features" aria-labelledby="features-title">
  <div class="container">
    <header class="section-header reveal">
      <h2 id="features-title" class="section-title text-balance">Vì sao chọn VegiFlow</h2>
      <p class="section-desc text-pretty">
        Thực phẩm chay chất lượng cao, kết hợp dịch vụ tận tâm để mỗi bữa ăn của bạn thêm nhẹ nhàng.
      </p>
    </header>

    <!-- Featured zig-zag rows -->
    <div class="featured-list">
      {featured.map((feat, i) => (
        <article
          class:list={['feature-row', 'reveal', { 'feature-row--reverse': i % 2 !== 0 }]}
        >
          <div class="feature-image-col">
            <div class="feature-image-wrap">
              <img
                src={feat.image}
                alt=""
                loading="lazy"
                class="feature-image"
              />
              <span class="feature-icon-badge" aria-hidden="true">
                <i class={`ph ${feat.icon}`}></i>
              </span>
            </div>
          </div>
          <div class="feature-text-col">
            <h3 class="feature-title">{feat.title}</h3>
            <p class="feature-desc text-pretty">{feat.desc}</p>
            <ul class="feature-points" role="list">
              {feat.points.map((p) => (
                <li>
                  <i class="ph ph-seal-check" aria-hidden="true"></i>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <!-- Secondary compact grid -->
    <div class="more-grid">
      {more.map((m, i) => (
        <article class:list={['more-card', 'reveal', `reveal-delay-${(i % 3) + 1}`]}>
          <span class="more-icon" aria-hidden="true"><i class={`ph ${m.icon}`}></i></span>
          <h3 class="more-title">{m.title}</h3>
          <p class="more-desc text-pretty">{m.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: var(--space-section);
    background: var(--color-bg-warm);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: var(--ls-tight);
    color: var(--color-deep);
    margin-bottom: var(--space-sm);
  }

  .section-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 520px;
    margin-inline: auto;
  }

  /* ── Featured rows ──────────────────────── */
  .featured-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5xl);
    margin-bottom: var(--space-5xl);
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .feature-row--reverse .feature-image-col {
    order: 2;
  }

  .feature-image-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: 0 24px 48px -22px rgba(20, 83, 45, 0.3);
    background: #f5faed;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .feature-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }

  .feature-row:hover .feature-image-wrap {
    transform: translateY(-3px);
  }

  .feature-icon-badge {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    font-size: 1.6rem;
    color: #fff;
    background: rgba(34, 166, 90, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 16px;
    box-shadow: 0 10px 24px -8px rgba(20, 83, 45, 0.4);
  }

  .feature-text-col {
    max-width: 460px;
  }

  .feature-row--reverse .feature-text-col {
    margin-left: auto;
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-deep);
    margin-bottom: var(--space-md);
    letter-spacing: var(--ls-tight);
  }

  .feature-desc {
    font-size: var(--text-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .feature-points {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .feature-points li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text);
  }

  .feature-points i {
    font-size: 1.1rem;
    color: var(--color-primary);
  }

  /* ── Secondary grid ─────────────────────── */
  .more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .more-card {
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) ease;
  }

  .more-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 38px -22px rgba(20, 83, 45, 0.28);
    border-color: var(--color-primary-light);
  }

  .more-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    font-size: 1.4rem;
    color: var(--color-primary);
    background: var(--color-primary-muted);
    border-radius: 13px;
    margin-bottom: var(--space-md);
  }

  .more-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-deep);
    margin-bottom: var(--space-xs);
    letter-spacing: var(--ls-tight);
  }

  .more-desc {
    font-size: var(--text-small);
    line-height: var(--lh-body);
    color: var(--color-text-secondary);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 768px) {
    .feature-row {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .feature-row--reverse .feature-image-col {
      order: 0;
    }

    .feature-text-col {
      max-width: none;
    }

    .feature-row--reverse .feature-text-col {
      margin-left: 0;
    }

    .feature-image-wrap {
      aspect-ratio: 16 / 9;
    }

    .more-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
