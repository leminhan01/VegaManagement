---
const featured = [
  {
    icon: 'ph-leaf',
    label: 'Đa dạng lựa chọn',
    title: 'Đủ món chay ngon cho mọi bữa ăn',
    desc: 'Từ rau củ tươi, hạt và gia vị đến món ăn sẵn, VegiFlow giúp bạn dễ dàng chọn đủ nguyên liệu cho một bữa chay trọn vị.',
    image: 'https://res.cloudinary.com/draoz2f7p/image/upload/v1783548436/chatbot_vegi_jjxlb2.png',
    imageAlt: 'Các sản phẩm thực phẩm chay của VegiFlow',
    points: ['Hơn 100 sản phẩm thuần thực vật', 'Danh mục rõ ràng, dễ tìm món', 'Nhiều lựa chọn cho từng ngân sách'],
    cta: 'Khám phá sản phẩm',
  },
  {
    icon: 'ph-shopping-bag-open',
    label: 'Mua sắm tiện lợi',
    title: 'Chọn nhanh, đặt gọn, nhận hàng tươi',
    desc: 'Xem giá và tồn kho rõ ràng, nhận tư vấn đúng nhu cầu rồi đặt hàng chỉ trong vài bước. Đơn được đóng gói cẩn thận và giao tận nơi.',
    image: 'https://res.cloudinary.com/draoz2f7p/image/upload/v1783548190/shipping_ay44il.png',
    imageAlt: 'Đơn hàng VegiFlow được đóng gói và giao tận nơi',
    points: ['Giao nội thành trong 2 đến 4 giờ', 'Freeship cho đơn từ 300.000đ', 'Đổi trả thuận tiện trong 7 ngày'],
    cta: 'Mua ngay hôm nay',
  },
];

const promises = [
  {
    icon: 'ph-shield-check',
    title: 'Thực phẩm an toàn',
    desc: 'Sản phẩm được chọn lọc kỹ, bảo quản đúng cách và kiểm tra hạn dùng trước khi giao.',
  },
  {
    icon: 'ph-coins',
    title: 'Giá hợp lý mỗi ngày',
    desc: 'Giá bán và ưu đãi hiển thị rõ ràng để bạn dễ chọn món ngon vừa với ngân sách.',
  },
  {
    icon: 'ph-seal-check',
    title: 'Nguồn gốc minh bạch',
    desc: 'Thành phần, nơi sản xuất và thông tin dị ứng được trình bày rõ trên từng sản phẩm.',
  },
  {
    icon: 'ph-truck',
    title: 'Giao hàng giữ độ tươi',
    desc: 'Đơn được đóng gói phù hợp với từng nhóm thực phẩm và giao nhanh trong nội thành.',
  },
  {
    icon: 'ph-chats-circle',
    title: 'Tư vấn đúng nhu cầu',
    desc: 'Nhắn VegiFlow để tìm món theo khẩu vị, chế độ ăn, dị ứng hoặc ngân sách của bạn.',
  },
  {
    icon: 'ph-arrows-counter-clockwise',
    title: 'Đổi trả rõ ràng',
    desc: 'VegiFlow hỗ trợ nhanh khi sản phẩm giao sai, hư hỏng hoặc không đạt chất lượng.',
  },
];
---

<section class="features" id="features" aria-labelledby="features-title">
  <div class="container">
    <header class="section-header reveal">
      <div class="section-heading">
        <span class="section-kicker">Mua đồ chay dễ dàng hơn</span>
        <h2 id="features-title" class="section-title text-balance">
          Vì sao chọn <span>VegiFlow?</span>
        </h2>
      </div>
      <p class="section-desc text-pretty">
        Sản phẩm chay đa dạng, thông tin minh bạch và trải nghiệm mua hàng thuận tiện cho bữa ăn ngon mỗi ngày.
      </p>
    </header>

    <div class="featured-list">
      {featured.map((feat, i) => (
        <article
          class:list={['feature-row', 'reveal', { 'feature-row--reverse': i % 2 !== 0 }]}
        >
          <div class="feature-image-col">
            <div class="feature-image-wrap">
              <img
                src={feat.image}
                alt={feat.imageAlt}
                loading="lazy"
                class="feature-image"
              />
              <span class="feature-icon-badge" aria-hidden="true">
                <i class={`ph ${feat.icon}`}></i>
              </span>
            </div>
          </div>
          <div class="feature-text-col">
            <span class="feature-label">{feat.label}</span>
            <h3 class="feature-title text-balance">{feat.title}</h3>
            <p class="feature-desc text-pretty">{feat.desc}</p>
            <ul class="feature-points" role="list">
              {feat.points.map((point) => (
                <li>
                  <i class="ph ph-check-circle" aria-hidden="true"></i>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
            <a class="feature-cta" href="#store">
              <span>{feat.cta}</span>
              <i class="ph ph-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="promise-panel reveal" aria-label="Cam kết mua hàng từ VegiFlow">
      <div class="promise-intro">
        <span class="promise-mark" aria-hidden="true"><i class="ph ph-plant"></i></span>
        <p class="text-balance">Chọn món chay bằng sự an tâm, không bằng phỏng đoán.</p>
      </div>
      <div class="promise-list">
        {promises.map((promise, i) => (
          <article class:list={['promise-item', `reveal-delay-${i + 1}`]}>
            <span class="promise-icon" aria-hidden="true"><i class={`ph ${promise.icon}`}></i></span>
            <div>
              <h3>{promise.title}</h3>
              <p class="text-pretty">{promise.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: var(--space-section);
    background: var(--color-bg-warm);
  }

  .section-header {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    align-items: end;
    gap: var(--space-2xl);
    margin-bottom: var(--space-4xl);
  }

  .section-kicker,
  .feature-label {
    display: block;
    color: var(--color-primary-hover);
    font-size: var(--text-small);
    font-weight: 700;
    letter-spacing: var(--ls-wide);
    margin-bottom: var(--space-sm);
  }

  .section-title {
    max-width: 720px;
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-tight);
    color: var(--color-deep);
  }

  .section-title span {
    color: var(--color-primary);
  }

  .section-desc {
    max-width: 500px;
    color: var(--color-text-secondary);
    font-size: var(--text-body);
  }

  .featured-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5xl);
    margin-bottom: var(--space-4xl);
  }

  .feature-row {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.88fr);
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: center;
  }

  .feature-row--reverse {
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
  }

  .feature-row--reverse .feature-image-col {
    order: 2;
  }

  .feature-row--reverse .feature-text-col {
    margin-left: auto;
  }

  .feature-image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid rgba(34, 166, 90, 0.12);
    border-radius: var(--radius-xl);
    background: #eef7e8;
    box-shadow: 0 28px 58px -30px rgba(20, 83, 45, 0.36);
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .feature-row:hover .feature-image-wrap {
    transform: translateY(-4px);
  }

  .feature-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .feature-icon-badge {
    position: absolute;
    left: var(--space-lg);
    bottom: var(--space-lg);
    display: inline-flex;
    width: 56px;
    height: 56px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 16px;
    background: rgba(34, 166, 90, 0.94);
    box-shadow: 0 12px 28px -10px rgba(20, 83, 45, 0.45);
    color: #fff;
    font-size: 1.55rem;
    backdrop-filter: blur(8px);
  }

  .feature-text-col {
    max-width: 480px;
  }

  .feature-title {
    margin-bottom: var(--space-md);
    color: var(--color-deep);
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3vw, 2.45rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: var(--ls-tight);
  }

  .feature-desc {
    margin-bottom: var(--space-lg);
    color: var(--color-text-secondary);
    font-size: var(--text-body);
    line-height: var(--lh-body);
  }

  .feature-points {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-bottom: var(--space-xl);
    list-style: none;
  }

  .feature-points li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text);
    font-size: var(--text-small);
    font-weight: 550;
  }

  .feature-points i {
    flex: 0 0 auto;
    color: var(--color-primary);
    font-size: 1.15rem;
  }

  .feature-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 46px;
    padding: 0.7rem 1.1rem;
    border-radius: var(--radius-md);
    background: var(--color-deep);
    color: #fff;
    font-size: var(--text-small);
    font-weight: 650;
    white-space: nowrap;
    transition:
      background var(--duration-fast) ease,
      transform var(--duration-fast) ease;
  }

  .feature-cta:hover {
    background: var(--color-deep-hover);
    color: #fff;
  }

  .feature-cta:active {
    transform: translateY(1px);
  }

  .feature-cta i {
    transition: transform var(--duration-fast) ease;
  }

  .feature-cta:hover i {
    transform: translateX(3px);
  }

  .promise-panel {
    display: grid;
    grid-template-columns: minmax(230px, 0.7fr) minmax(0, 1.7fr);
    gap: var(--space-2xl);
    padding: clamp(1.5rem, 4vw, 3rem);
    border-radius: var(--radius-xl);
    background: var(--color-deep);
    color: #fff;
    box-shadow: 0 24px 56px -30px rgba(20, 83, 45, 0.55);
  }

  .promise-intro {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .promise-mark {
    display: inline-flex;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.12);
    color: #86efac;
    font-size: 1.4rem;
  }

  .promise-intro p {
    max-width: 280px;
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: var(--ls-tight);
  }

  .promise-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .promise-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-lg);
    border-left: 1px solid rgba(255, 255, 255, 0.14);
  }

  .promise-item:nth-child(n + 4) {
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }

  .promise-icon {
    color: #86efac;
    font-size: 1.25rem;
  }

  .promise-item h3 {
    margin-bottom: var(--space-xs);
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.3;
  }

  .promise-item p {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-small);
    line-height: 1.55;
  }

  @media (max-width: 900px) {
    .section-header {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .feature-row,
    .feature-row--reverse {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .promise-panel {
      grid-template-columns: 1fr;
    }

    .promise-intro {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
    }

    .promise-item:first-child {
      border-left: none;
    }
  }

  @media (max-width: 700px) {
    .section-header {
      margin-bottom: var(--space-2xl);
    }

    .featured-list {
      gap: var(--space-4xl);
      margin-bottom: var(--space-3xl);
    }

    .feature-row,
    .feature-row--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .feature-row--reverse .feature-image-col {
      order: 0;
    }

    .feature-row--reverse .feature-text-col {
      margin-left: 0;
    }

    .feature-image-wrap {
      aspect-ratio: 16 / 10;
    }

    .promise-intro {
      align-items: flex-start;
    }

    .promise-list {
      grid-template-columns: 1fr;
    }

    .promise-item,
    .promise-item:first-child {
      padding: var(--space-lg) 0;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.14);
    }
  }
</style>
