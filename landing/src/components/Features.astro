---
const features = [
  {
    icon: '🤖',
    title: 'AI tư vấn thông minh',
    desc: 'Chatbot AI hiểu nhu cầu của bạn, tư vấn sản phẩm phù hợp dựa trên sở thích, chế độ dinh dưỡng và ngân sách.',
    image: 'https://picsum.photos/seed/veg-ai/800/600',
  },
  {
    icon: '🔍',
    title: 'Tìm kiếm ngữ nghĩa',
    desc: 'Công nghệ RAG giúp tìm sản phẩm theo ý nghĩa, không chỉ từ khóa. Hỏi "món nào nhiều protein" và nhận gợi ý chính xác.',
    image: 'https://picsum.photos/seed/veg-search/800/600',
  },
  {
    icon: '🚚',
    title: 'Giao hàng siêu tốc',
    desc: 'Giao nội thành TP.HCM trong 2-4 giờ. Freeship cho đơn từ 300.000đ. Đổi trả trong vòng 7 ngày.',
    image: 'https://picsum.photos/seed/veg-delivery/800/600',
  },
  {
    icon: '📱',
    title: 'Đa nền tảng',
    desc: 'Chat qua Web, Zalo, hoặc Facebook Messenger. Bất cứ đâu, bất cứ lúc nào.',
    image: 'https://picsum.photos/seed/veg-platform/800/600',
  },
  {
    icon: '🌱',
    title: 'Nguồn gốc rõ ràng',
    desc: 'Mọi sản phẩm đều có thông tin nguồn gốc, thành phần, chứng nhận VietGAP/Organic.',
    image: 'https://picsum.photos/seed/veg-organic/800/600',
  },
  {
    icon: '💬',
    title: 'Hỗ trợ 24/7',
    desc: 'AI assistant luôn sẵn sàng trả lời câu hỏi, tra cứu đơn hàng, và hỗ trợ bạn mọi lúc.',
    image: 'https://picsum.photos/seed/veg-support/800/600',
  },
];
---

<section class="features" id="features" aria-labelledby="features-title">
  <div class="container">
    <header class="section-header reveal">
      <p class="section-eyebrow">Tại sao chọn chúng tôi</p>
      <h2 id="features-title" class="section-title text-balance">Trải nghiệm mua sắm thông minh</h2>
      <p class="section-desc text-pretty">Kết hợp công nghệ AI với thực phẩm chay chất lượng cao</p>
    </header>

    <div class="features-list">
      {features.map((feat, i) => (
        <article
          class:list={[
            'feature-row',
            'reveal',
            { 'feature-row--reverse': i % 2 !== 0 },
          ]}
        >
          <div class="feature-image-col">
            <div class="feature-image-wrap">
              <img
                src={feat.image}
                alt=""
                loading="lazy"
                class="feature-image"
              />
            </div>
          </div>
          <div class="feature-text-col">
            <span class="feature-icon" aria-hidden="true">{feat.icon}</span>
            <h3 class="feature-title">{feat.title}</h3>
            <p class="feature-desc text-pretty">{feat.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: var(--space-section);
    background: var(--color-bg-warm);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .section-eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: var(--ls-tight);
    color: var(--color-deep);
    margin-bottom: var(--space-sm);
  }

  .section-desc {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin-inline: auto;
  }

  /* ── Zig-zag rows ──────────────────────── */
  .features-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .feature-row--reverse {
    direction: rtl;
  }

  .feature-row--reverse > * {
    direction: ltr;
  }

  /* Image */
  .feature-image-col {
    position: relative;
  }

  .feature-image-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow-lg);
  }

  .feature-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .feature-row:hover .feature-image {
    transform: scale(1.03);
  }

  /* Text */
  .feature-text-col {
    max-width: 440px;
  }

  .feature-row--reverse .feature-text-col {
    margin-left: auto;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    font-size: 1.5rem;
    background: var(--color-primary-muted);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-lg);
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 700;
    color: var(--color-deep);
    margin-bottom: var(--space-md);
    letter-spacing: var(--ls-tight);
  }

  .feature-desc {
    font-size: var(--text-body);
    line-height: var(--lh-relaxed);
    color: var(--color-text-secondary);
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 768px) {
    .feature-row,
    .feature-row--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .feature-row--reverse {
      direction: ltr;
    }

    .feature-text-col {
      max-width: none;
    }

    .feature-row--reverse .feature-text-col {
      margin-left: 0;
    }

    .feature-image-wrap {
      aspect-ratio: 16 / 10;
    }
  }
</style>
